    "kit": {
      "info": {
        "contact": {
          "url": "https://github.com/Thatskat/southpark-quotes-api"
        },
        "description": "A pretty simple API to let you retrieve some of the best quotes from South Park, mmkay! Retrieve quotes from South Park characters with options for random quotes, specific number of quotes, and searching by term.",
        "license": {
          "name": "MIT",
          "url": "https://github.com/Thatskat/southpark-quotes-api/blob/main/LICENSE"
        },
        "servers": [
          {
            "description": "Production server",
            "url": "https://southparkquotes.onrender.com"
          }
        ],
        "title": "South Park Quotes API",
        "version": "1.0.0",
        "tagline": "Fetch random and searchable quotes from South Park characters",
        "homepage": "https://southparkquotes.onrender.com",
        "docs_url": "https://github.com/Thatskat/southpark-quotes-api",
        "license_short": "MIT License",
        "license_md": "- Released under the MIT License.\n- Free to use, modify, and redistribute with attribution.\n- South Park names, characters, and quotes remain the property of their respective rights holders; this API is an unofficial fan project.",
        "about_md": "The South Park Quotes API is a small community-maintained service that returns quotes from characters of the animated series *South Park*. It is hosted at [southparkquotes.onrender.com](https://southparkquotes.onrender.com) and the source lives on GitHub at [Thatskat/southpark-quotes-api](https://github.com/Thatskat/southpark-quotes-api).\n\nWhat you get from the API:\n\n- A random quote from `GET /v1/quotes`\n- A specific number of random quotes from `GET /v1/quotes/{number}` (e.g. `/v1/quotes/3`)\n- Quotes filtered by character name or text from `GET /v1/quotes/search/{searchTerm}` (e.g. `/v1/quotes/search/randy`)\n- Each quote object contains a `quote` string and a `character` string.\n\nThe API is open: no authentication or API key is required, and CORS is enabled so it can be called directly from browser code. The quote dataset is community-curated through pull requests on the upstream GitHub repository.",
        "entity_desc": {
          "quote": "A single South Park quote with its attributed `character`, exposed via `GET /v1/quotes`, `GET /v1/quotes/{number}`, and `GET /v1/quotes/search/{searchTerm}`."
        },
        "auth": false
      },
